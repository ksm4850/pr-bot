# ── Agent Mode ────────────────────────────────────────────────────
# "api"        = Anthropic API 직접 호출 (크레딧 소모)
# "claude-code" = claude CLI subprocess 사용 (구독제)
AGENT_MODE=api

# ── Claude Agent ─────────────────────────────────────────────────
# AGENT_MODE api 일때
ANTHROPIC_API_KEY=
# AGENT_MODE cladue-code 일때
CLAUDE_TOKENS=
# ── Sentry Webhook ────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_WEBHOOK_SECRET=

# ── Database ──────────────────────────────────────────────────────
# 기본값: data/jobs.db
# DATABASE_PATH=data/jobs.db

# ── Worker ────────────────────────────────────────────────────────
# Job 폴링 간격 (초), 기본값: 5
# WORKER_POLL_INTERVAL=5

# ── Workspace ─────────────────────────────────────────────────────
# git clone 저장 위치, 기본값: /tmp/pr-bot-workspaces
 WORKSPACE_DIR=
